# MindStore Environment Variables
# Copy this to .env.local (or .env for docker-compose) and fill in your values.
#
# For a complete walk-through covering Vercel + Neon + Stripe setup, see
# docs/deploy/production.md.

# ─── Required ───────────────────────────────────────────────
# PostgreSQL with pgvector + pg_trgm + pgcrypto extensions.
# Anywhere Postgres lives works: Neon (recommended via Vercel
# Marketplace), Supabase, Railway, self-hosted.
DATABASE_URL=postgres://mindstore:yourpassword@localhost:5432/mindstore

# ─── Security ───────────────────────────────────────────────
# 32-byte random string. API keys are encrypted at rest with this; if
# you ever rotate it, every encrypted setting becomes unreadable.
# Generate: openssl rand -hex 32
ENCRYPTION_KEY=
# 32-byte random string. NextAuth uses this to sign session JWTs.
# Generate: openssl rand -hex 32
AUTH_SECRET=

# ─── AI Providers (at least one path required) ──────────────
# These are the FALLBACK keys used if a user hasn't pasted their own
# in Settings. For multi-user / paid SaaS, leave these blank and
# either let users BYO or configure MINDSTORE_AI_GATEWAY_KEY below.

# Google Gemini (free tier available)
# GEMINI_API_KEY=AIza...

# OpenAI
# OPENAI_API_KEY=sk-...

# Ollama (free, local — install from https://ollama.ai)
# OLLAMA_URL=http://localhost:11434

# OpenRouter (200+ models via one key — https://openrouter.ai)
# OPENROUTER_API_KEY=sk-or-...

# ─── Authentication ─────────────────────────────────────────
# Without GOOGLE_*, MindStore runs in single-user mode (no login).
# For ANY public deployment, set ALLOW_SINGLE_USER_MODE=false so
# unauthenticated requests are rejected rather than falling back to
# the shared default user.
# GOOGLE_CLIENT_ID=...
# GOOGLE_CLIENT_SECRET=...
# ALLOW_SINGLE_USER_MODE=true
# NEXT_PUBLIC_URL=https://mindstore.org

# ─── Subscription billing (Stripe) ──────────────────────────
# Required ONLY if you want to sell paid subscriptions. Self-host and
# free deployments don't need any of these.
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_PERSONAL=price_...
# STRIPE_PRICE_PRO=price_...

# ─── Bundled AI mode (Vercel AI Gateway) ────────────────────
# Required ONLY if you want subscriptions to include AI tokens
# (rather than only acting as a flat platform fee for BYO-key users).
# Enable Vercel AI Gateway in your project, then paste the key here.
# MINDSTORE_AI_GATEWAY_KEY=

# Set to 'true' to allow self-hosted single-user deployments to also
# route through bundled mode. Off by default — there's nobody to
# charge in single-user mode.
# MINDSTORE_BUNDLED_FOR_DEFAULT_USER=false

# ─── MCP CORS ───────────────────────────────────────────────
# Comma-separated origins allowed to make cross-origin requests to
# /api/mcp. Same-origin and Bearer-authed requests work without
# this; only add origins for browser-based MCP clients.
# MCP_ALLOWED_ORIGINS=https://app.example.com,https://other.example.com

# ─── Server (optional) ──────────────────────────────────────
# PORT=3000
# NODE_ENV=production
